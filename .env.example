# Environment Variables Example
# Copy to .env and replace with your actual values
# Get bot token from: https://discord.com/developers/applications

BOT_TOKEN="your-bot-token-here"
GUILD_ID="your-guild-id-here"

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# However you will have to change adapter in `src/lib/prisma/index.ts` if you are not using SQLite.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
# This template is preconfigured with SQLite, no need to edit if you are using SQLite.

DATABASE_URL="file:./src/db/discord.db"